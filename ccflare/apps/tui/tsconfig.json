{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/react",
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"types": ["bun-types", "react"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
